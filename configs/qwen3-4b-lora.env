# A conservative first LoRA configuration for the Apple M5 with 24 GB unified memory.
# The MLX checkpoint was downloaded manually into this directory, so use its local
# path by default and avoid any Hugging Face download during training.
# Source this through scripts/train_lora.sh; command-line environment variables override it.

MODEL=${MODEL:-configs}
DATA_DIR=${DATA_DIR:-data/processed}
ADAPTER_PATH=${ADAPTER_PATH:-adapters/qwen3-4b-physics-v1}

ITERS=${ITERS:-600}
LEARNING_RATE=${LEARNING_RATE:-1e-5}
BATCH_SIZE=${BATCH_SIZE:-1}
MAX_SEQ_LENGTH=${MAX_SEQ_LENGTH:-1024}
NUM_LAYERS=${NUM_LAYERS:-16}
